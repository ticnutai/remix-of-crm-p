# Frontend (Vite) environment variables
# Safe to commit: contains NO secrets.
#
# IMPORTANT:
# - Any variable starting with VITE_ is bundled into the frontend and is visible in the browser.
# - Supabase "anon" key is EXPECTED to be public.
# - Never put Supabase service_role key in any VITE_ variable.

VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"

# ONLYOFFICE is configured as Supabase Edge Function secrets, not public Vite vars:
# ONLYOFFICE_DOCUMENT_SERVER_URL="https://your-onlyoffice-document-server"
# ONLYOFFICE_JWT_SECRET="your-document-server-jwt-secret"
